rules_version = '2';

// TheCryptoDesk Firestore security rules.
//
// All writes happen from the ingest Cloud Function via the Admin SDK, which
// bypasses these rules entirely. Therefore the client is read-only and may
// only read published posts. Everything else is locked down.
service cloud.firestore {
  match /databases/{database}/documents {

    // Published news posts are publicly readable. No client writes.
    match /posts/{slug} {
      allow read: if resource.data.status == 'published';
      allow write: if false;
    }

    // Date-archive index (counts per month). Publicly readable; Admin-SDK writes.
    match /archives/{ym} {
      allow read: if true;
      allow write: if false;
    }

    // Server-only dedup ledger. Never exposed to clients.
    match /seen/{hash} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
