{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "apphosting": [
    {
      "backendId": "thecryptodesk",
      "rootDir": "/",
      "alwaysDeployFromSource": true,
      "ignore": [
        "node_modules",
        ".git",
        ".firebase",
        "firebase-debug.log",
        "**/*.local"
      ]
    }
  ],
  "emulators": {
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true },
    "singleProjectMode": true
  }
}
